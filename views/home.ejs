<% layout("/layouts/boilerplate") %>

<section class="py-5">
  <div class="row align-items-center g-4">
    <div class="col-lg-7">
      <span class="badge text-bg-warning mb-3">Community Book Marketplace</span>
      <h1 class="display-5 fw-bold mb-3">Buy and Sell Second-hand Books Easily</h1>
      <p class="lead text-muted mb-4">
        Discover affordable books from other readers, list your own collection, and connect directly with buyers.
      </p>
      <div class="d-flex flex-wrap gap-2">
        <a href="/booklistings" class="btn btn-dark btn-lg">Explore Books</a>
        <a href="/booklistings/new" class="btn btn-outline-dark btn-lg">List a Book</a>
      </div>
    </div>
    <div class="col-lg-5">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <h5 class="card-title mb-3">How It Works</h5>
          <ol class="mb-0">
            <li class="mb-2">Sign up and add your book listings.</li>
            <li class="mb-2">Buyers discover books via search.</li>
            <li class="mb-0">Get notified when someone clicks Buy.</li>
          </ol>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="pb-5">
  <div class="row g-3">
    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
          <h5 class="card-title">Smart Search</h5>
          <p class="card-text text-muted mb-0">
            Search books quickly by title or author to find what you need.
          </p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
          <h5 class="card-title">Buyer Alerts</h5>
          <p class="card-text text-muted mb-0">
            Receive notifications when someone shows interest in your listing.
          </p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
          <h5 class="card-title">Reviews</h5>
          <p class="card-text text-muted mb-0">
            Check ratings and comments before choosing a book.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="pb-5">
  <div class="p-4 p-md-5 rounded-4 bg-light border">
    <div class="row align-items-center g-3">
      <div class="col-md-8">
        <h3 class="mb-2">Ready to share your books?</h3>
        <p class="text-muted mb-0">
          Start by adding a listing and help another reader find their next favorite book.
        </p>
      </div>
      <div class="col-md-4 text-md-end">
        <a href="/booklistings/new" class="btn btn-success btn-lg">Add New Book</a>
      </div>
    </div>
  </div>
</section>
