<% layout("/layouts/boilerplate") %>

<div class="container mt-4">
    <div class="card col mb-4 show">
        <img src="<%= book.image.url %>" class="card-img-top show-image" alt="book-image">
        <div class="card-body">
            <h3 class="card-title mb-3 "><%= book.title %></h3>
            <p class="card-text"><%= book.description %></p>
            <p class="card-text"><b>Author:</b> <%= book.author %></p>
            <p class="card-text"><b>Price:</b> <%= book.price != null 
                ? book.price.toLocaleString("en-IN") 
                : "Price not available" %></p>
        </div>
        
        <div class="card-footer ">
<form action="/booklistings/<%= book._id %>/edit">
    <button class="btn btn-success mt-3 mb-3 edit"><i class="fa-solid fa-pen-to-square"></i> Edit</button>
</form>

<form action="/booklistings/<%= book._id %>?_method=DELETE" method="post">
    <button class="btn btn-danger mt-3 mb-3 delete"><i class="fa-solid fa-trash"></i> Delete</button>
</form>

<!-- Buy Button -->

<% if(currentUser && book.owner && currentUser._id.toString() !== book.owner._id.toString()) { %>
    <% if(!book.isBuyRequestSent){ %>
      <form action="/booklistings/<%= book.owner._id %>/<%= currentUser._id %>/<%= book._id %>/buy" method="post" class="buy-form" data-price="<%= book.price || 0 %>" data-wallet="<%= currentUser.wallet || 0 %>">
          <button class="btn btn-warning mt-3 mb-3 delete buybtn"><i class="fa-solid fa-cart-shopping"></i>Buy</button>
      </form>
    <% } else { %>
      <button class="btn btn-success mt-3 mb-3 delete buybtn" disabled><i class="fa-solid fa-circle-check"></i>Buy Request Sent</button>
    <% } %>
<% } else if (currentUser && !book.owner) { %>
    <button class="btn btn-secondary mt-3 mb-3 delete buybtn" disabled>Owner unavailable</button>
<% } %>
        </div>
    </div>
    <hr>

        <div class="row">
        <div class="col-12 col-md-8 offset-md-2">
            <h4>Leave a Review</h4>

            <form action="/booklistings/<%= book._id %>/reviews" method="post" novalidate class="needs-validation">
                <div class="mb-3">
                    <label for="rating" class="form-label">Rating</label>
                    <input
                        type="range"
                        id="rating"
                        name="review[rating]"
                        min="1"
                        max="5"
                        class="form-range"
                        required>
                </div>

                <div class="mb-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea
                        name="review[comment]"
                        id="comment"
                        class="form-control"
                        rows="4"
                        required></textarea>
                    <div class="invalid-feedback">
                        Please provide a comment.
                    </div>
                </div>

                <button class="btn btn-outline-dark">Submit</button>
                
            </form>
            <br>
        </div>
<hr>
<% if(book.reviews.length!==0) {%>
        <div class="col-12 col-md-8 offset-md-2">
            <h4>Reviews</h4>
            <% for(let review of book.reviews) { %>
            <div class="card mb-3">
                <div class="d-flex align-items-center gap-2 px-3 pt-3">
                    <span class="fw-semibold text-dark name">Author: <%= review.author ? review.author.username : "Anonymous" %></span>
                </div>
                <div class="card-body"><p class="card-text rating"><b>Rating:</b>
                    <% for(let i=0;i<review.rating;i++){%>
                        <i class="fa-solid fa-star"></i>
                        <% }%>
                        </p>
                    <p class="card-text"><b>Comment:</b> <%= review.comment %></p>
                </div>
                <form action="/booklistings/<%= book._id %>/reviews/<%= review._id %>?_method=DELETE" method="post">
                    <button class="btn btn-outline-dark revdel">Delete</button>
                </form>
            </div>
            <% } %>
        </div>
        <% } else { %> <div class="col-12 col-md-8 offset-md-2 mb-4"><h4 class="text-center">No Reviews Available</h4></div> <% } %>

        
    </div>
</div>


<script>
  document.addEventListener("DOMContentLoaded", () => {
    const buyForm = document.querySelector(".buy-form");
    if (!buyForm) return;

    buyForm.addEventListener("submit", (event) => {
      const bookPrice = Number(buyForm.dataset.price || 0);
      const walletBalance = Number(buyForm.dataset.wallet || 0);

      if (walletBalance < bookPrice) {
        event.preventDefault();
        const shortage = bookPrice - walletBalance;
        alert(
          `You cannot buy this book. Your balance is Rs. ${walletBalance.toLocaleString("en-IN")}, but this book costs Rs. ${bookPrice.toLocaleString("en-IN")}. You need Rs. ${shortage.toLocaleString("en-IN")} more.`
        );
      }
    });
  });
</script>
